# Same Supabase project as the CRM
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# Server-only Supabase service role key (for cron / privileged reads). Optional but recommended.
SUPABASE_SERVICE_ROLE_KEY=

# Protects the cron endpoint. Set the same value in the Vercel Cron job header.
CRON_SECRET=

# Email notifications (optional - no-op if unset)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=Withers Time <time@withers-ventures.com>

# SMS notifications via Twilio (optional - no-op if unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
